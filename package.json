{
  "name": "decision-helper-tool",
  "version": "1.0.0",
  "description": "Multi-Criteria Decision Analysis (MCDA) tool for comparing options and understanding trade-offs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:ui": "cd src/ui && npm run build",
    "dev": "ts-node src/index.ts",
    "dev:api": "ts-node src/api/index.ts",
    "dev:ui": "cd src/ui && npm start",
    "start": "node dist/index.js",
    "start:api": "node dist/api/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "decision-analysis",
    "mcda",
    "comparison",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^3.15.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "morgan": "^1.10.1",
    "puppeteer": "^24.34.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0"
  }
}
